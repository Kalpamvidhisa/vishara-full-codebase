# ─── SMS (Twilio) ────────────────────────────────────────────────────────────
# Required for sending appointment confirmation SMS via /appointments
SMS_API_KEY=your_secret_api_key_here
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Client-side key (must match SMS_API_KEY above)
VITE_SMS_API_KEY=your_secret_api_key_here

# ─── Gemini AI (Google AI Studio) ─────────────────────────────────────────────
# Optional client-side API Key to power live Symptom Checker and Disease Analyzer.
# Can also be set interactively inside the web app UI.
VITE_GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Notes ───────────────────────────────────────────────────────────────────
# Firebase config is already hardcoded in src/lib/firebase.ts
# For production, move Firebase config here too using VITE_FIREBASE_* vars

