# Vishara Firestore Security Rules
# Add these rules in Firebase Console → Firestore → Rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users collection ───────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Login history (write-only for authenticated users) ─────────────────
    match /login_history/{docId} {
      allow create: if request.auth != null;
      allow read: if false; // Only admin reads this
    }

    // ── Appointments ───────────────────────────────────────────────────────
    match /appointments/{docId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    // ── Calls (signaling for in-app VoIP) ─────────────────────────────────
    // Both caller and receiver can read/write their own calls
    match /calls/{callId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && (
        resource.data.callerId == request.auth.uid ||
        resource.data.receiverId == request.auth.uid
      );
      allow update: if request.auth != null && (
        resource.data.callerId == request.auth.uid ||
        resource.data.receiverId == request.auth.uid
      );
      allow delete: if false;
    }
  }
}
